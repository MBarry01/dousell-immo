    },
    {
      "id": "apollo-enrich",
      "name": "🚀 Apollo.io — Enrich Company",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1720, 240],
      "parameters": {
        "method": "POST",
        "url": "https://api.apollo.io/v1/organizations/enrich",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "api_key", "value": "={{ $env.APOLLO_API_KEY }}" },
            { "name": "domain", "value": "={{ $('normalize-lead').item.json.website ? $('normalize-lead').item.json.website.replace(/https?:\\/\\//, '').split('/')[0] : '' }}" },
            { "name": "name", "value": "={{ $('normalize-lead').item.json.company_name }}" }
          ]
        },
        "options": { "ignoreResponseCode": true }
      }
    },
    {
      "id": "merge-apollo-data",
      "name": "🔀 Merge Apollo Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1900, 240],
      "parameters": {
        "jsCode": "const lead = $('normalize-lead').item.json;\nconst apollo = $input.item.json.organization || {};\n\nreturn [{\n  json: {\n    ...lead,\n    linkedin_url: apollo.linkedin_url || null,\n    website: lead.website || (apollo.primary_domain ? `https://${apollo.primary_domain}` : null),\n    employees_count: apollo.estimated_num_employees || 0,\n    score_details: {\n      ...lead.score_details,\n      has_linkedin: !!apollo.linkedin_url,\n      employees: apollo.estimated_num_employees || 0\n    }\n  }\n}];"
      }
    },
    {
      "id": "hunter-find-email",
      "name": "📧 Hunter.io — Find Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [2080, 240],
      "parameters": {
        "method": "GET",
        "url": "https://api.hunter.io/v2/domain-search",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "domain", "value": "={{ $json.website ? $json.website.replace(/https?:\\/\\//, '').split('/')[0] : '' }}" },
            { "name": "api_key", "value": "={{ $env.HUNTER_API_KEY }}" },
            { "name": "limit", "value": "5" },
            { "name": "type", "value": "generic" }
          ]
        },
        "options": { "ignoreResponseCode": true }
      }
    },
    {
      "id": "extract-best-email",
      "name": "📬 Extract Best Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2260, 240],
      "parameters": {
        "jsCode": "const lead = $('merge-apollo-data').item.json;\nconst hunterData = $input.item.json.data || {};\nconst emails = hunterData.emails || [];\n\nlet bestEmail = null;\nlet emailSource = null;\n\nif (emails.length > 0) {\n  const genericEmail = emails.find(e => e.type === 'generic');\n  const highConfidence = emails.sort((a, b) => (b.confidence || 0) - (a.confidence || 0))[0];\n  const picked = genericEmail || highConfidence;\n  if (picked && picked.confidence >= 70) {\n    bestEmail = picked.value;\n    emailSource = 'hunter_domain';\n  }\n}\n\nreturn [{\n  json: {\n    ...lead,\n    email: bestEmail,\n    email_verified: false,\n    email_source: emailSource\n  }\n}];"
      }
    },
    {
      "id": "hunter-verify",
      "name": "✔️ Hunter.io — Verify Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [2440, 240],
      "parameters": {
        "method": "GET",
        "url": "https://api.hunter.io/v2/email-verifier",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "email", "value": "={{ $json.email || 'noemail@example.com' }}" },
            { "name": "api_key", "value": "={{ $env.HUNTER_API_KEY }}" }
          ]
        },
        "options": { "ignoreResponseCode": true }
      }
    },
    {
      "id": "merge-verification",
      "name": "🔀 Merge Verification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2620, 240],
      "parameters": {
        "jsCode": "const lead = $('extract-best-email').item.json;\nconst verifyData = $input.item.json.data || {};\n\nreturn [{\n  json: {\n    ...lead,\n    email_verified: verifyData.status === 'valid'\n  }\n}];"
      }
    },
    {
      "id": "calculate-score",
      "name": "🎯 Calculate Lead Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2800, 240],
      "parameters": {
        "jsCode": "const lead = $input.item.json;\nconst details = lead.score_details || {};\nlet score = 0;\n\n// Email (30 pts)\nif (lead.email && lead.email_verified) score += 30;\nelse if (lead.email) score += 15;\n\n// Site web (15 pts)\nif (lead.website) score += 15;\n\n// Téléphone (10 pts)\nif (lead.phone) score += 10;\n\n// LinkedIn (10 pts)\nif (lead.linkedin_url) score += 10;\n\n// Taille entreprise (20 pts)\nconst emp = details.employees || 0;\nif (emp >= 10) score += 20;\nelse if (emp >= 5) score += 10;\nelse if (emp >= 1) score += 5;\n\n// Activité Google (15 pts)\nconst reviews = details.reviews_count || 0;\nif (reviews >= 50) score += 15;\nelse if (reviews >= 20) score += 10;\nelse if (reviews >= 5) score += 5;\n\nreturn [{\n  json: {\n    ...lead,\n    score: Math.min(score, 100),\n    score_details: {\n      ...details,\n      score_breakdown: {\n        email: lead.email && lead.email_verified ? 30 : (lead.email ? 15 : 0),\n        website: lead.website ? 15 : 0,\n        phone: lead.phone ? 10 : 0,\n        linkedin: lead.linkedin_url ? 10 : 0,\n        employees: emp >= 10 ? 20 : (emp >= 5 ? 10 : (emp >= 1 ? 5 : 0)),\n        activity: reviews >= 50 ? 15 : (reviews >= 20 ? 10 : (reviews >= 5 ? 5 : 0))\n      }\n    }\n  }\n}];"
      }
    },
    {
      "id": "filter-qualified",
      "name": "⭐ Filter Score ≥ 40",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [2980, 240],
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{ $json.score }}",
              "rightValue": 40,
              "operator": { "type": "number", "operation": "gte" }
            }
          ],
          "combinator": "and"
        }
      }
    },
