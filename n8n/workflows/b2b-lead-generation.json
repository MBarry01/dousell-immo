      "position": [820, 240],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
    },
    {
      "id": "google-maps-details",
      "name": "📋 Google Maps — Get Details",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1000, 240],
      "parameters": {
        "method": "GET",
        "url": "https://maps.googleapis.com/maps/api/place/details/json",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "place_id", "value": "={{ $json.place_id }}" },
            { "name": "fields", "value": "name,formatted_address,formatted_phone_number,website,rating,user_ratings_total" },
            { "name": "language", "value": "fr" },
            { "name": "key", "value": "={{ $env.GOOGLE_MAPS_API_KEY }}" }
          ]
        }
      }
    },
    {
      "id": "normalize-lead",
      "name": "🔧 Normalize Lead Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1180, 240],
      "parameters": {
        "jsCode": "const place = $input.item.json.result || {};\nconst placeId = $('loop-places').item.json.place_id;\n\nreturn [{\n  json: {\n    company_name: place.name || 'Unknown',\n    source: 'google_maps',\n    source_id: placeId,\n    google_place_id: placeId,\n    phone: place.formatted_phone_number || null,\n    website: place.website || null,\n    address: place.formatted_address || null,\n    city: 'Dakar',\n    listings_count: place.user_ratings_total || 0,\n    score_details: {\n      has_website: !!place.website,\n      has_phone: !!place.formatted_phone_number,\n      rating: place.rating || 0,\n      reviews_count: place.user_ratings_total || 0\n    }\n  }\n}];"
      }
    },
    {
      "id": "check-duplicate",
      "name": "🔍 Check Duplicate (Supabase)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1360, 240],
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/b2b_prospects",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "google_place_id", "value": "=eq.{{ $json.google_place_id }}" },
            { "name": "select", "value": "id,status" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" }
          ]
        }
      }
    },
    {
      "id": "filter-new-only",
