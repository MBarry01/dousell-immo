          "parameters": [
            { "name": "query", "value": "={{ $json.queries[0] }}" },
            { "name": "language", "value": "fr" },
            { "name": "region", "value": "SN" },
            { "name": "key", "value": "={{ $env.GOOGLE_MAPS_API_KEY }}" }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "loop-places",
      "name": "🔄 Loop Over Places",
      "type": "n8n-nodes-base.splitInBatches",
