        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  company_name: $json.company_name,\n  source: $json.source,\n  source_id: $json.source_id,\n  google_place_id: $json.google_place_id,\n  email: $json.email || null,\n  email_verified: $json.email_verified || false,\n  email_source: $json.email_source || null,\n  phone: $json.phone || null,\n  website: $json.website || null,\n  linkedin_url: $json.linkedin_url || null,\n  address: $json.address || null,\n  city: $json.city || 'Dakar',\n  score: $json.score,\n  score_details: $json.score_details,\n  listings_count: $json.listings_count || 0,\n  status: 'qualified'\n}) }}"
      }
